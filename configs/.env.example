# AutoGen API Style Agent — Environment Configuration
# Copy to .env and fill in your API keys. At least one provider is required.

# ─── OpenAI ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── Together.ai ─────────────────────────────────────────────────────
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# ─── OpenRouter ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ─── Google Gemini ───────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# ─── Kimi (Moonshot) ────────────────────────────────────────────────
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2-0520

# ─── Mistral ────────────────────────────────────────────────────────
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# ─── Server Configuration ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
DEFAULT_PROVIDER=openai

# ─── GitHub Integration (optional) ──────────────────────────────────
GITHUB_TOKEN=

# ─── Session Management ─────────────────────────────────────────────
SESSION_TTL_SECONDS=3600
MAX_SESSIONS=100
