# AutoGen API Style Agent — Environment Configuration
# Copy to .env and fill in your API keys. At least one provider is required.

# ─── OpenAI ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── Together.ai ─────────────────────────────────────────────────────
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# ─── OpenRouter ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ─── Google Gemini ───────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# ─── Kimi (Moonshot) ────────────────────────────────────────────────
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2-0520

# ─── Mistral ────────────────────────────────────────────────────────
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# ─── Server Configuration ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
DEFAULT_PROVIDER=openai

# ─── GitHub Integration (optional) ──────────────────────────────────
GITHUB_TOKEN=

# ─── Session Management ─────────────────────────────────────────────
SESSION_TTL_SECONDS=3600
MAX_SESSIONS=100

# ─── Frontend AI Providers (SvelteKit) ──────────────────────────────
# These are used by the Elysium AI OS frontend (src/routes/api/chat/)
# At least one is required for the frontend chat to work.
ANTHROPIC_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=

# Optional: Override OpenAI base URL for custom endpoints
# OPENAI_BASE_URL=

# Optional: Override OpenRouter base URL
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: Google Generative AI key for the frontend.
# The frontend uses GOOGLE_GENERATIVE_AI_API_KEY, while the Python backend uses GOOGLE_API_KEY.
GOOGLE_GENERATIVE_AI_API_KEY=

# ─── Web Search (Frontend) ──────────────────────────────────────────
# The frontend search feature (src/routes/api/search/) tries providers in order:
# Tavily → Serper → Brave → mock fallback
TAVILY_API_KEY=
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=

# ─── Supabase ───────────────────────────────────────────────────
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
