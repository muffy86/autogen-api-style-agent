# ============================================================================
# AutoGen API Style Agent + Elysium AI OS — Environment Configuration
# ============================================================================
# Copy to .env and fill in your keys. At least ONE AI provider key is required.
# NEVER commit .env — it is gitignored.

# ─── Python Backend: LLM Providers ─────────────────────────────────────────
# The Python AutoGen backend (src/autogen_api_agent/) uses these keys.
# Only ONE provider key is needed; the system auto-detects availability.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2-0520

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# ─── Python Backend: Server Configuration ──────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
DEFAULT_PROVIDER=openai
SESSION_TTL_SECONDS=3600
MAX_SESSIONS=100

# ─── Python Backend: GitHub Integration (optional) ─────────────────────────
GITHUB_TOKEN=

# ─── SvelteKit Frontend: AI Providers ──────────────────────────────────────
# The frontend (src/routes/api/chat/) uses these keys.
# Shares OPENAI_API_KEY / OPENROUTER_API_KEY with the backend above.
ANTHROPIC_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=
# Google: frontend uses GOOGLE_GENERATIVE_AI_API_KEY; backend uses GOOGLE_API_KEY.
GOOGLE_GENERATIVE_AI_API_KEY=

# ─── SvelteKit Frontend: Web Search Providers ──────────────────────────────
# Frontend search tries providers in order: Tavily → Serper → Brave → mock fallback.
TAVILY_API_KEY=
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=

# ─── Supabase (required for frontend auth & storage) ───────────────────────
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── NanoClaw Telegram Bot (optional) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# ─── Smoke / Post-Deploy Verification ──────────────────────────────────────
# Overridden in CI; used by scripts/smoke-test.sh and scripts/post-deploy-verify.sh.
SMOKE_BACKEND_URL=http://localhost:8000
SMOKE_FRONTEND_URL=http://localhost:5173
DEPLOY_URL=
