{
  "$schema": "https://capy.ai/settings.schema.json",
  "hooks": {
    "setup": [
      "pnpm install",
      "pip install -e '.[dev]'"
    ],
    "terminals": [
      { "name": "web", "command": "pnpm dev" },
      { "name": "api", "command": "pip install -e . && agent serve --reload" }
    ],
    "previews": [
      { "name": "web", "port": 5173 },
      { "name": "api", "port": 8000 }
    ]
  }
}
