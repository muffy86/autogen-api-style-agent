# Sovereign Intelligence OS environment
SOVEREIGN_MEMORY_PATH=~/.sovereign-os/memory
SOVEREIGN_IDENTITY_PATH=~/.sovereign-os/identity.md
SOVEREIGN_HOST=127.0.0.1
SOVEREIGN_PORT=8000
SOVEREIGN_LOG_LEVEL=INFO

# LLM routing
SOVEREIGN_DEFAULT_MODEL=ollama/llama3.2
OLLAMA_API_BASE=http://127.0.0.1:11434

# Optional provider keys (LiteLLM reads these)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
TOGETHERAI_API_KEY=
GEMINI_API_KEY=

# MCP
MCP_SERVERS_CONFIG=./configs/mcp_servers.json

# Tasker trigger shared secret — any caller must present this header
SOVEREIGN_TRIGGER_TOKEN=change-me-to-a-long-random-value
